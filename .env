# ── Telegram ──────────────────────────────────────────────────
BOT_TOKEN=8739787678:AAGUaTtSZOmO_8kruLPo8BOdwJTrRkk2J48
# Оставьте пустым для polling (разработка) или укажите для webhook (продакшен)
WEBHOOK_BASE_URL=
BOT_PORT=8080

# ── PostgreSQL (своя БД на Timeweb VDS) ──────────────────────
# В docker-compose используется имя сервиса "postgres"
DATABASE_URL=postgresql+asyncpg://requestbot:23a3e03baf30d0fb07deb2ae@postgres:5432/requestbot
POSTGRES_PASSWORD=23a3e03baf30d0fb07deb2ae

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT и безопасность ────────────────────────────────────────
API_SECRET_KEY=b5ef58a5a08fc8d1b7cc080730aab2f1a886403ef9a437e158fe2df04237d0f9
JWT_EXPIRE_MINUTES=1440

# ── CORS (адреса фронтендов) ──────────────────────────────────
CORS_ORIGINS=["https://app.yourdomain.com","https://admin.yourdomain.com"]

# ── Ollama (бесплатный LLM на VDS) ───────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3
# Включить AI-классификацию (требует загрузки модели ollama pull llama3)
OLLAMA_ENABLED=false

# ── SLA (часы) ────────────────────────────────────────────────
DEFAULT_SLA_HOURS=24
CRITICAL_SLA_HOURS=4
HIGH_SLA_HOURS=8
NORMAL_SLA_HOURS=24
LOW_SLA_HOURS=72

# ── Дубликаты (0.0 - 1.0, чем выше — тем строже) ────────────
DUPLICATE_SIMILARITY_THRESHOLD=0.80

# ── Уведомления ───────────────────────────────────────────────
WAITING_REMINDER_HOURS=48
POST_RESOLVE_SURVEY_HOURS=24
NOTIFICATION_RETRY_LIMIT=3

# ── Rate limiting (сообщений в минуту от одного пользователя)
RATE_LIMIT_PER_MINUTE=10
