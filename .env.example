# ── Telegram ──────────────────────────────────────────────────
BOT_TOKEN=replace-with-telegram-bot-token
# Для продакшена используйте публичный backend-домен с webhook path.
WEBHOOK_BASE_URL=
# Для кнопок Web App используйте публичный Mini App домен.
MINIAPP_BASE_URL=
BOT_PORT=8080

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://requestbot:replace-with-password@postgres:5432/requestbot
POSTGRES_PASSWORD=replace-with-postgres-password

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT и безопасность ────────────────────────────────────────
API_SECRET_KEY=replace-with-random-secret
JWT_EXPIRE_MINUTES=1440

# ── CORS (адреса фронтендов) ──────────────────────────────────
CORS_ORIGINS=["https://app.24beershop.ru","https://admin.24beershop.ru"]

# ── Ollama ────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_FALLBACK_MODEL=qwen2.5:1.5b
OLLAMA_ENABLED=false

# ── SLA (часы) ────────────────────────────────────────────────
DEFAULT_SLA_HOURS=24
CRITICAL_SLA_HOURS=4
HIGH_SLA_HOURS=8
NORMAL_SLA_HOURS=24
LOW_SLA_HOURS=72

# ── Дубликаты ─────────────────────────────────────────────────
DUPLICATE_SIMILARITY_THRESHOLD=0.80

# ── Уведомления ───────────────────────────────────────────────
WAITING_REMINDER_HOURS=48
POST_RESOLVE_SURVEY_HOURS=24
NOTIFICATION_RETRY_LIMIT=3

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=10
